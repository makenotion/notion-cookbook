      "status": "ready",
      "language": "typescript",
      "runtime": "node",
      "integrations": ["notion-api", "sendgrid"],
      "entrypoints": ["index.ts"],
      "commands": {
        "install": "npm install",
        "run": "npm run ts-run"
      }
    },
