# Copy this file to `.env` for local testing only. `.env` is gitignored.
#
# Zendesk webhook signing secret (from Zendesk Admin > Webhooks > Reveal secret):
# ZENDESK_WEBHOOK_SECRET=

# Zendesk subdomain — e.g. for https://acme.zendesk.com use "acme".
# Optional if every webhook payload includes ticket_url.
# ZENDESK_SUBDOMAIN=

# Notion database ID or URL (paste from the Zendesk tickets database):
# ZENDESK_NOTION_DATABASE_ID=

# ---------------------------------------------------------------------------
# Zendesk API credentials (used to fetch comments and canonical ticket status)
# Provide ONE of the three options below.
# ---------------------------------------------------------------------------

# Option 1 — base64-encoded "email/token:api_token" or "Basic <base64>":
# ZENDESK_BASIC_AUTH_TOKEN=

# Option 2 — full Authorization header value ("Basic …" or "Bearer …"):
# ZENDESK_AUTHORIZATION=

# Option 3 — email + API token (the worker builds the Basic auth header):
# ZENDESK_API_TOKEN=
# ZENDESK_API_USER_EMAIL=
