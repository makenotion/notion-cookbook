# Copy to .env for local runs (ntn workers exec --local reads it automatically).
# For the deployed worker, upload with `ntn workers env push` after deploy
# (or set individually: ntn workers env set KEY=value).
#
# .env is gitignored — never commit real keys.
#
# You only need keys for ONE office to start (US or Europe). Fill in whichever
# you have and set the matching toggle in src/config.ts (uspto / epo); leave
# the other blank and turn its toggle off. Add the second office later by
# supplying its keys and flipping its toggle back on.

# ── Applicant name(s) to track (optional) ───────────────────────────────
# Normally set in src/config.ts (`applicants`). To override without editing
# code, set a comma-separated list here (e.g. "Acme Corporation,Acme LLC").
# PORTFOLIO_APPLICANTS=

# ── USPTO Open Data Portal (United States) ──────────────────────────────
# Free API key — register for ODP access at https://data.uspto.gov/support/universal-registration
# NOTE: MyODP (data.uspto.gov) is NOT the older MyUSPTO (my.uspto.gov).
# Requires a USPTO.gov account verified with ID.me; then the key is instant.
# Required only if config.sources.uspto is true.
USPTO_API_KEY=

# ── EPO Open Patent Services (OPS) (Europe) ─────────────────────────────
# Register a free account at https://developers.epo.org (Non-paying), then
# My Apps -> Add a new App (Core APIs) for an OAuth consumer key + secret.
# No ID check, but the account must be APPROVED by EPO (confirmation email)
# before you can create keys. Required only if config.sources.epo is true.
EPO_CONSUMER_KEY=
EPO_CONSUMER_SECRET=

# Notion workspace auth is handled by `ntn login` — no token needed here for
# the base template. The optional attachProsecutionDocumentToPage tool is the
# one exception: it needs a Notion integration token for its file upload.
# NOTION_API_TOKEN=

# ── Your docketing system (optional) ────────────────────────────────────
# See src/sources/docketing.example.ts. Add whatever auth your system needs.
# DOCKETING_API_KEY=

# ── Your e-billing / spend system (optional) ────────────────────────────
# See src/sources/spend.example.ts.
# SPEND_CLIENT_ID=
# SPEND_CLIENT_SECRET=

# ── Operator escape hatch (see README "Runbook") ────────────────────────
# STALENESS_CAP_EXEMPT=
