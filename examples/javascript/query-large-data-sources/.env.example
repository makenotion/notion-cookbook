# Your Notion integration token. Create one at
# https://www.notion.com/my-integrations and share the target database with it.
NOTION_API_KEY=

# The data source to query. In the Notion app, open the database, then copy the
# data source ID from the ... menu > Manage data sources, or from the API. A
# database can hold several data sources.
NOTION_DATA_SOURCE_ID=

# Optional. Override the API host and version, e.g. for a self-managed setup.
# Leave blank to use the defaults.
# NOTION_BASE_URL=
# NOTION_VERSION=
