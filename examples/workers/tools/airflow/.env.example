# Copy this file to `.env` and fill in your own values for local testing.
# `.env` is gitignored — never commit real credentials.
# For a deployed worker, set these with `ntn workers env set KEY=value` instead.

# Required
# Base URL of your Airflow instance WITHOUT the /api/v1 suffix,
# e.g. https://airflow.example.com
AIRFLOW_URL=
# Bearer token used to authenticate with the Airflow REST API (Airflow 2.x).
AIRFLOW_API_KEY=
